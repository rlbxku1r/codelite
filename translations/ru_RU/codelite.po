"DLL"

#: wxcrafter/controls/top_level_win_wrapper.cpp:80
#: wxcrafter/top_level_windows/AuiToolBarTopLevel.cpp:20
#: wxcrafter/top_level_windows/AuiToolBarTopLevel.cpp:42
#: wxcrafter/top_level_windows/image_list_wrapper.cpp:18
msgid "The generated C++ class name"
msgstr "Имя создаваемого класса C++"

#: wxcrafter/controls/top_level_win_wrapper.cpp:114
msgid ""
"You did not set the 'Inherited C++ Class Properties -> File name' property "
