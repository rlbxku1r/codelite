msgstr ""
"Редактор ячейки был скрыт. Обрабатывается тип события "
"wxEVT_GRID_EDITOR_HIDDEN."

#: wxcrafter/controls/grid_wrapper.cpp:61
msgid ""
"The editor for a cell was shown. Processes a wxEVT_GRID_EDITOR_SHOWN event "
"type"
msgstr ""
"Редактор ячейки был показан. Обрабатывается тип события "
"wxEVT_GRID_EDITOR_SHOWN."

#: wxcrafter/controls/grid_wrapper.cpp:63
